{
  "name": "@wovosoft/wovoui-icons",
  "version": "1.1.13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && bun run generate:types",
    "build:tsc": "vite build && bun run generate:tsc_types",
    "preview": "vite preview",
    "generate:icons": "node src/generate_icons.js",
    "generate:types": "node src/copyTypes.js",
    "generate:tsc_types": "vue-tsc --declaration --emitDeclarationOnly --outdir ./dist"
  },
  "dependencies": {
    "bootstrap-icons": "^1.13.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@babel/types": "^7.29.7",
    "@types/node": "^18.19.130",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vue-tsc": "^3.3.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*.mjs",
      "types": "./dist/components/*.d.ts"
    },
    "./style.css": "./dist/wovoui-icons.css",
    "./dist/wovoui-icons.css": "./dist/wovoui-icons.css"
  },
  "description": "Bootstrap Icons in Vue 3",
  "author": "Narayan Adhikary",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wovosoft/wovoui-icons.git"
  },
  "keywords": [
    "Bootstrap 5",
    "Icons",
    "Vue 3",
    "wovoui",
    "wovoui-icons"
  ],
  "bugs": {
    "url": "https://github.com/wovosoft/wovoui-icons/issues"
  },
  "homepage": "https://github.com/wovosoft/wovoui-icons#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}